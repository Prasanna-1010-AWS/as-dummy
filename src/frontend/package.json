{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,

  "scripts": {
    "dev": "npm run grpc:generate && node -r ./utils/telemetry/Instrumentation.js ./node_modules/next/dist/bin/next dev",
    "build": "npm run grpc:generate && next build",
    "start": "node --require ./Instrumentation.js server.js",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "cy:open": "cypress open",

    "grpc:generate": "mkdir -p ./protos && protoc -I ../../pb --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=esModuleInterop=true --ts_proto_out=./protos --ts_proto_opt=outputServices=grpc-js demo.proto"
  },

  "dependencies": {
    "@grpc/grpc-js": "1.14.4",

    "@openfeature/core": "1.9.0",
    "@openfeature/web-sdk": "1.9.0",
    "@openfeature/react-sdk": "1.4.1",
    "@openfeature/flagd-provider": "0.13.2",
    "@openfeature/flagd-web-provider": "0.7.2",

    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/auto-instrumentations-web": "0.64.0",
    "@opentelemetry/context-zone": "2.8.0",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/instrumentation": "0.219.0",
    "@opentelemetry/resource-detector-aws": "2.19.0",
    "@opentelemetry/resource-detector-container": "0.8.10",
    "@opentelemetry/resource-detector-gcp": "0.54.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/sdk-trace-node": "2.8.0",
    "@opentelemetry/sdk-trace-web": "2.8.0",

    "@tanstack/react-query": "5.64.1",
    "cookies-next": "5.1.0",
    "currency-symbol-map": "5.1.0",
    "dotenv": "16.4.7",
    "dotenv-expand": "12.0.1",

    "next": "15.5.19",
    "react": "18.2.0",
    "react-dom": "18.2.0",

    "sharp": "0.33.5",
    "styled-components": "6.1.14",
    "ts-proto": "1.181.1",
    "uuid": "11.0.5"
  },

  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@types/styled-components": "5.1.34",
    "@types/uuid": "10.0.0",

    "@typescript-eslint/eslint-plugin": "8.21.0",
    "@typescript-eslint/parser": "8.21.0",

    "cypress": "14.0.0",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.1.0",

    "openapi-typescript": "7.5.2",
    "typescript": "5.7.3",

    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "@testing-library/react": "14.3.1",
    "@testing-library/jest-dom": "6.0.0",

    "ts-proto": "1.181.1"
  }
}